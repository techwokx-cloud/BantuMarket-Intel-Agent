# BantuMarket Intel Agent - Environment Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to Git - it contains secrets

# ============================================================================
# ANTHROPIC (Claude AI)
# ============================================================================
# Get your API key from: https://console.anthropic.com/api_keys
# Should start with: sk-ant-
ANTHROPIC_API_KEY=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

# ============================================================================
# BRIGHT DATA (Web Intelligence)
# ============================================================================
# Get credentials from: https://brightdata.com/cp/zones
# Your customer ID: hl_23226031

# SERP API Configuration
BRIGHT_DATA_API_KEY=Describe what are you looking for...
API Key=76f6116d-94f0-4efc-9585-c5b8f06c759d
BRIGHT_DATA_SERP_ZONE=serp_api1
BRIGHT_DATA_CUSTOMER_ID=hl_23226031

# Native Proxy Access (Alternative method)
# Host: brd.superproxy.io
# Port: 33335
BRIGHT_DATA_PROXY_HOST=brd.superproxy.io
BRIGHT_DATA_PROXY_PORT=33335
BRIGHT_DATA_PROXY_USERNAME=brd-customer-hl_23226031-zone-serp_api1
BRIGHT_DATA_PROXY_PASSWORD=your_proxy_password_here

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Streamlit configuration
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=true
STREAMLIT_SERVER_RUN_ON_SAVE=false

# API Rate Limiting
API_RATE_LIMIT=100  # requests per minute
API_TIMEOUT=30      # seconds

# Data Caching
CACHE_TTL=3600      # seconds (1 hour)
ENABLE_CACHE=true

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable specific features
ENABLE_REAL_TIME_PRICING=true
ENABLE_COMPETITOR_MONITORING=true
ENABLE_REGULATORY_ALERTS=true
ENABLE_SUPPLIER_RISK=true
ENABLE_MARKET_ANALYSIS=true
ENABLE_CHARTS=true
ENABLE_EXPORT=true

# ============================================================================
# MARKET DATA SOURCES
# ============================================================================
# Target markets for intelligence gathering
TARGET_MARKETS=Ghana,Nigeria,Kenya,South Africa,Côte d'Ivoire,Burkina Faso,Tanzania,Uganda,Ethiopia,Senegal

# Commodities to track
TRACKED_COMMODITIES=Shea Butter,Cocoa,Maize,Coffee,Cashews,Sesame Seeds,Ginger

# Currency pairs to monitor
MONITORED_PAIRS=USD/GHS,USD/NGN,USD/KES,USD/ZAR,USD/XOF,USD/TZS,USD/ETB

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/bantumarket.log
ENABLE_ANALYTICS=true
SENTRY_DSN=  # Optional: error tracking

# ============================================================================
# SECURITY & SSL
# ============================================================================
# SSL Certificate for Bright Data proxies
# Download from: https://brightdata.com/static/brightdata_proxy_ca.zip
BRIGHT_DATA_SSL_CERT_PATH=./certs/brightdata_proxy_ca.crt
VERIFY_SSL=true  # Set to false only for development

# ============================================================================
# DEPLOYMENT (Streamlit Cloud)
# ============================================================================
# For Streamlit Cloud, add these secrets in the web interface:
# Settings → Secrets → paste these as key=value pairs:
# 
# ANTHROPIC_API_KEY
# BRIGHT_DATA_API_KEY
# BRIGHT_DATA_PROXY_PASSWORD
#
# DO NOT paste ENVIRONMENT variables - Streamlit Cloud handles those

# ============================================================================
# NOTES FOR SETUP
# ============================================================================
#
# 1. LOCAL DEVELOPMENT:
#    cp .env.example .env
#    Edit .env with your actual credentials
#    Never commit .env to Git
#
# 2. STREAMLIT CLOUD:
#    Settings → Secrets → add secrets one by one
#    Use web interface, don't upload .env file
#
# 3. BRIGHT DATA SETUP:
#    - Go to https://brightdata.com/cp/zones
#    - Create SERP API zone (named: serp_api1)
#    - Copy your API key
#    - Copy your proxy credentials
#    - Paste into this .env file
#
# 4. ANTHROPIC SETUP:
#    - Go to https://console.anthropic.com/api_keys
#    - Create new API key
#    - Copy and paste into ANTHROPIC_API_KEY
#
# 5. VERIFY CREDENTIALS:
#    python test_credentials.py
#    (script will test all API connections)
